psql --username=freecodecamp --dbname=postgres
CREATE DATABASE universe;
\c universe
-- 1. Crear Tablas
CREATE TABLE galaxy (
    galaxy_id SERIAL PRIMARY KEY,
    name VARCHAR(100) NOT NULL UNIQUE,
    galaxy_type TEXT NOT NULL,
    age_in_millions_of_years INT NOT NULL,
    distance_from_earth NUMERIC,
    has_life BOOLEAN DEFAULT FALSE
);

CREATE TABLE star (
    star_id SERIAL PRIMARY KEY,
    name VARCHAR(100) NOT NULL UNIQUE,
    galaxy_id INT NOT NULL REFERENCES galaxy(galaxy_id),
    spectral_type VARCHAR(10) NOT NULL,
    temperature_kelvin INT,
    is_spherical BOOLEAN DEFAULT TRUE
);

CREATE TABLE planet (
    planet_id SERIAL PRIMARY KEY,
    name VARCHAR(100) NOT NULL UNIQUE,
    star_id INT NOT NULL REFERENCES star(star_id),
    planet_type VARCHAR(50) NOT NULL,
    mass_earth_masses NUMERIC NOT NULL,
    has_life BOOLEAN DEFAULT FALSE
);

CREATE TABLE moon (
    moon_id SERIAL PRIMARY KEY,
    name VARCHAR(100) NOT NULL UNIQUE,
    planet_id INT NOT NULL REFERENCES planet(planet_id),
    radius_km INT NOT NULL,
    is_spherical BOOLEAN DEFAULT FALSE,
    discovery_year INT
);

CREATE TABLE constellation (
    constellation_id SERIAL PRIMARY KEY,
    name VARCHAR(100) NOT NULL UNIQUE,
    visible_season VARCHAR(50) NOT NULL,
    number_of_stars INT NOT NULL
);

-- 2. Insertar Datos
